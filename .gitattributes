# Ensure shell scripts always have LF line endings when checked out
# (they run on Linux/Pi — CRLF will break the shebang line)
*.sh           text eol=lf

# Text files — normalize to LF in repo, check out with platform line endings
*.c            text eol=lf
*.h            text eol=lf
*.md           text eol=lf
*.txt          text eol=lf
*.conf         text eol=lf
*.cfg          text eol=lf
*.ini          text eol=lf
*.csv          text eol=lf
*.cmake        text eol=lf
CMakeLists.txt text eol=lf
*.py           text eol=lf
*.proto        text eol=lf
*.json         text eol=lf

# Windows scripts — keep CRLF
*.bat          text eol=crlf

# Binary files
*.bin          binary
*.elf          binary
