/dts-v1/;
/plugin/;

/*
 * Disable only the spidev child device on SPI bus 10 (Pi 5 SPI0 on the 40-pin
 * header).  Uses target-path (a string literal) instead of a phandle reference
 * so dtc can compile this without the base device tree present.
 *
 * Path confirmed from dmesg on Pi 5 running Pi OS Trixie:
 *   OF: overlay: ... /axi/pcie@1000120000/rp1/spi@50000/spidev@0/status
 *
 * This leaves the spi10 bus controller itself alive so the esp32_spi kernel
 * module can claim it, while preventing the spidev driver from binding first.
 */
/ {
	compatible = "brcm,bcm2712";

	fragment@0 {
		target-path = "/axi/pcie@1000120000/rp1/spi@50000/spidev@0";
		__overlay__ {
			status = "disabled";
		};
	};
};
